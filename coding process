    rating:4.8, reviews:166, desc:'Hand-loomed by artisans in the Portuguese highlands using natural dyes. Each piece is unique, a work of functional art for your sofa or bed.', colors:['#c4856a','#9e9e7a','#5a6e8a'], sizes:['130×180cm','160×220cm'] },
];

let cart = [];
let currentFilter = 'all';

// ── RENDER PRODUCTS ──
function renderProducts(filter) {
  const grid = document.getElementById('products-grid');
  const filtered = filter === 'all' ? products
    : filter === 'sale' ? products.filter(p => p.badge === 'Sale')
    : products.filter(p => p.category === filter);

  grid.innerHTML = filtered.map(p => {
    const inCart = cart.some(c => c.id === p.id);
    return `
    <div class="product-card" onclick="showDetail(${p.id})">
      <div class="product-img-wrap">
        <img class="product-img" src="${p.img}" alt="${p.name}" loading="lazy">
        ${p.badge ? `<div class="product-badge ${p.badge.toLowerCase()}">${p.badge}</div>` : ''}
        <div class="product-wishlist" onclick="event.stopPropagation(); this.classList.toggle('active')">♡</div>
      </div>
      <div class="product-info">
        <div class="product-category">${p.category}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-rating">
          <div class="stars-sm">${'★'.repeat(Math.floor(p.rating))}${'☆'.repeat(5-Math.floor(p.rating))}</div>
          <div class="rating-count">${p.rating} (${p.reviews})</div>
        </div>
        <div class="product-footer">
          <div class="product-price">
            ${p.oldPrice ? `<span class="old">$${p.oldPrice}</span>` : ''}$${p.price}
          </div>
          <button class="add-btn ${inCart?'added':''}" onclick="event.stopPropagation(); addToCart(${p.id}, this)">
            ${inCart ? '✓ Added' : '+ Add'}
          </button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function filterProducts(filter) {
  currentFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  event && event.target && event.target.classList.add('active');
  renderProducts(filter);
}

// ── PRODUCT DETAIL ──
function showDetail(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;

  document.getElementById('detail-content').innerHTML = `
  <div class="detail-grid" style="padding:0 4% 4rem">
    <div class="detail-visual">
      <div class="detail-main-img">
        <img class="detail-emoji" id="detail-main-img" src="${p.img}" alt="${p.name}">
      </div>
      <div class="detail-thumbs">
      ${p.thumbs.map((src,i) => `<div class="thumb ${i===0?'active':''}" onclick="document.getElementById('detail-main-img').src='${src}'; this.parentElement.querySelectorAll('.thumb').forEach(t=>t.classList.remove('active')); this.classList.add('active')"><img src="${src}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" loading="lazy"></div>`).join('')}
      </div>
    </div>
    <div class="detail-info">
      <div class="detail-category">${p.category}</div>
      <h1 class="detail-name">${p.name}</h1>
      <div class="detail-rating">
        <div class="stars-lg">${'★'.repeat(Math.floor(p.rating))}${'☆'.repeat(5-Math.floor(p.rating))}</div>
        <div class="rating-info">${p.rating} · ${p.reviews} reviews</div>
      </div>
      <div class="detail-price-row">
        <div class="detail-price">$${p.price}</div>
        ${p.oldPrice ? `<div class="detail-old-price">$${p.oldPrice}</div><div class="detail-discount">-${Math.round((1-p.price/p.oldPrice)*100)}%</div>` : ''}
      </div>
      <p class="detail-desc">${p.desc}</p>

      <span class="option-label">Color</span>
      <div class="color-options">
        ${p.colors.map((c,i) => `<div class="color-dot ${i===0?'active':''}" style="background:${c}" onclick="this.parentElement.querySelectorAll('.color-dot').forEach(d=>d.classList.remove('active')); this.classList.add('active')"></div>`).join('')}
      </div>

      <span class="option-label">Size</span>
      <div class="size-options">
        ${p.sizes.map((s,i) => `<button class="size-btn ${i===0?'active':''}" onclick="this.parentElement.querySelectorAll('.size-btn').forEach(b=>b.classList.remove('active')); this.classList.add('active')">${s}</button>`).join('')}
      </div>

      <div class="qty-atc">
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="changeQty(-1)">−</button>
          <span class="qty-num" id="detail-qty">1</span>
          <button class="qty-btn" onclick="changeQty(1)">+</button>
        </div>
        <button class="atc-btn" id="detail-atc-btn" onclick="addToCartDetail(${p.id})">
          <span>Add to Cart</span> · <span>$${p.price}</span>
        </button>
        <button class="wishlist-btn">♡ Save</button>
      </div>

      <div class="detail-meta">
        <div class="meta-item"><span class="meta-icon">🚚</span> Free shipping over $75</div>
        <div class="meta-item"><span class="meta-icon">↩️</span> 30-day returns</div>
        <div class="meta-item"><span class="meta-icon">🔒</span> Secure checkout</div>
        <div class="meta-item"><span class="meta-icon">✦</span> In stock · Ships in 2–3 days</div>
      </div>
    </div>
  </div>`;

  showPage('detail');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

let detailQty = 1;
function changeQty(delta) {
  detailQty = Math.max(1, Math.min(10, detailQty + delta));
  document.getElementById('detail-qty').textContent = detailQty;
}

// ── CART ──
function addToCart(id, btn) {
  const p = products.find(x => x.id === id);
  const existing = cart.find(c => c.id === id);
  if (existing) { existing.qty++; }
  else { cart.push({ ...p, qty: 1 }); }

  if (btn) { btn.textContent = '✓ Added'; btn.classList.add('added'); }
  updateCartUI();
  showToast(`✓ ${p.name} added to cart`);
}

function addToCartDetail(id) {
  const p = products.find(x => x.id === id);
  const existing = cart.find(c => c.id === id);
  if (existing) { existing.qty += detailQty; }
  else { cart.push({ ...p, qty: detailQty }); }

  const btn = document.getElementById('detail-atc-btn');
  if (btn) { btn.classList.add('added'); btn.innerHTML = '✓ Added to Cart'; }
  updateCartUI();
  showToast(`✓ ${p.name} × ${detailQty} added to cart`);
  detailQty = 1;
  const qtyEl = document.getElementById('detail-qty');
  if (qtyEl) qtyEl.textContent = 1;
}

function removeFromCart(id) {
  cart = cart.filter(c => c.id !== id);
  updateCartUI();
  renderCartItems();
}

function updateCartQty(id, delta) {
  const item = cart.find(c => c.id === id);
  if (!item) return;
  item.qty = Math.max(1, item.qty + delta);
  updateCartUI();
  renderCartItems();
}

function updateCartUI() {
  const total = cart.reduce((a, c) => a + c.qty, 0);
  const el = document.getElementById('cart-count');
  el.textContent = total;
  el.classList.toggle('show', total > 0);
  document.getElementById('cart-item-label').textContent = `(${total} item${total!==1?'s':''})`;
  const subtotal = cart.reduce((a,c) => a + c.price * c.qty, 0);
  document.getElementById('cart-subtotal-val').textContent = `$${subtotal.toFixed(2)}`;
  document.getElementById('cart-total-val').textContent = `$${subtotal.toFixed(2)}`;
  document.getElementById('cart-footer').style.display = cart.length ? 'block' : 'none';
}

function renderCartItems() {
  const list = document.getElementById('cart-items-list');
  if (cart.length === 0) {
    list.innerHTML = `<div class="cart-empty"><div class="cart-empty-icon">🛒</div><p>Your cart is empty.<br>Discover something beautiful.</p></div>`;
    return;
  }
  list.innerHTML = cart.map(item => `
    <div class="cart-item">
      <div class="cart-item-img"><img src="${item.img}" alt="${item.name}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;"></div>
      <div class="cart-item-details">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-meta">${item.category} · In Stock</div>
        <div class="cart-item-footer">
          <div class="cart-item-price">$${(item.price * item.qty).toFixed(2)}</div>
          <div class="cart-item-qty">
            <button class="cqty-btn" onclick="updateCartQty(${item.id},-1)">−</button>
            ${item.qty}
            <button class="cqty-btn" onclick="updateCartQty(${item.id},1)">+</button>
            <button class="cart-item-remove" onclick="removeFromCart(${item.id})">✕</button>
          </div>
        </div>
      </div>
    </div>`).join('');
}

function toggleCart() {
  const overlay = document.getElementById('cart-overlay');
  const drawer = document.getElementById('cart-drawer');
  const open = drawer.classList.toggle('open');
  overlay.classList.toggle('open', open);
  if (open) renderCartItems();
}

// ── PAGE SWITCHING ──
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(`page-${name}`).classList.add('active');
  if (name === 'shop') renderProducts(currentFilter);
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ── INIT ──
renderProducts('all');
</script>

